# CFA Portfolio RAG Deployment Configuration
# Copy this file to .env and fill in with real credentials

# Pinecone Configuration
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1
PINECONE_INDEX=portfolio-rag-384

# Optional legacy Pinecone environment (fallback if cloud/region not set)
PINECONE_ENVIRONMENT=us-east-1-aws

# Hugging Face Inference API Configuration
HF_API_KEY=your_hf_api_key_here
HF_GENERATION_MODEL=mistralai/Mistral-7B-Instruct-v0.2
HF_PROVIDER=featherless-ai
